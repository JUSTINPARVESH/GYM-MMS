rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: members
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - age: number (optional, 10-100)
    //   - phoneNumber: string (required, 10-15 chars)
    //   - gender: string (enum: Male, Female, Other)
    //   - membershipPlan: string (enum: Monthly Plan, 3 Month Plan, 6 Month Plan, Yearly Plan)
    //   - joinDate: timestamp (required)
    //   - expiryDate: timestamp (required)
    //   - paymentStatus: string (enum: Paid, Pending)
    //   - amountPaid: number (optional)
    //   - status: string (enum: Active, Expiring Soon, Expired)
    //   - aadhaarNumber: string (required, 12 chars)
    //   - address: string (required)
    //   - city: string (required)
    //   - state: string (required)
    //   - pincode: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
             ('email' in request.auth.token) &&
             (request.auth.token.email.lower() == "justinparvesh20@gmail.com") &&
             (request.auth.token.email_verified == true);
    }

    function isAdmin() {
      return isSuperAdmin() || 
        (isAuthenticated() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isValidMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 10 && data.phoneNumber.size() <= 15 &&
             data.membershipPlan in ['Monthly Plan', '3 Month Plan', '6 Month Plan', 'Yearly Plan'] &&
             data.paymentStatus in ['Paid', 'Pending'] &&
             data.joinDate is timestamp &&
             data.expiryDate is timestamp &&
             data.aadhaarNumber is string && data.aadhaarNumber.size() == 12 &&
             data.address is string && data.address.size() > 0 &&
             data.city is string && data.city.size() > 0 &&
             data.state is string && data.state.size() > 0 &&
             data.pincode is string && data.pincode.size() > 0 &&
             data.age is number &&
             data.amountPaid is number &&
             data.status in ['Active', 'Expiring Soon', 'Expired'];
    }

    // Rules for members collection
    match /members/{memberId} {
      allow read, write: if isSuperAdmin();
      allow get, list: if isAdmin();
      allow create, update: if isAdmin() && isValidMember(request.resource.data);
      allow delete: if isAdmin();
    }

    // Rules for users collection (Admins)
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isSuperAdmin();
      // Only super admin can create or update admin roles
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
